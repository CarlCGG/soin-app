generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = "postgresql://postgres:123456@localhost:5432/soindb?schema=public"
}

model User {
  id                Int                @id @default(autoincrement())
  email             String             @unique
  username          String             @unique
  password          String
  avatar            String?
  bio               String?
  createdAt         DateTime           @default(now())
  gender            String?
  phone             String?
  website           String?
  birthYear         String?
  ethnicity         String?
  location          String?
  tags              String?
  assets            Asset[]
  businesses        Business[]
  businessFollowers BusinessFollower[]
  comments          Comment[]
  connectionsFrom   Connection[]       @relation("ConnectionFrom")
  connectionsTo     Connection[]       @relation("ConnectionTo")
  events            Event[]
  eventAttendees    EventAttendee[]
  groups            GroupMember[]
  groupMessages     GroupMessage[]
  groupPosts        GroupPost[]        @relation("GroupPostAuthor")
  groupReviews      GroupReview[]      @relation("GroupReviewAuthor")
  likes             Like[]
  receivedMessages  Message[]          @relation("receiver")
  sentMessages      Message[]          @relation("sender")
  notifications     Notification[]
  posts             Post[]
  resources         Resource[]
  smartGoals        SmartGoal[]
}

model Post {
  id         Int       @id @default(autoincrement())
  content    String
  imageUrl   String?
  createdAt  DateTime  @default(now())
  authorId   Int
  visibility String    @default("everyone")
  comments   Comment[]
  likes      Like[]
  author     User      @relation(fields: [authorId], references: [id])
}

model Message {
  id         Int      @id @default(autoincrement())
  content    String
  createdAt  DateTime @default(now())
  senderId   Int
  receiverId Int
  receiver   User     @relation("receiver", fields: [receiverId], references: [id])
  sender     User     @relation("sender", fields: [senderId], references: [id])
}

model Like {
  id        Int      @id @default(autoincrement())
  postId    Int
  userId    Int
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([postId, userId])
}

model Comment {
  id        Int      @id @default(autoincrement())
  content   String
  createdAt DateTime @default(now())
  postId    Int
  authorId  Int
  author    User     @relation(fields: [authorId], references: [id])
  post      Post     @relation(fields: [postId], references: [id])
}

model Group {
  id          Int            @id @default(autoincrement())
  name        String
  description String?
  category    String?
  location    String?
  createdAt   DateTime       @default(now())
  creatorId   Int?
  members     GroupMember[]
  messages    GroupMessage[]
  posts       GroupPost[]
  reviews     GroupReview[]
}

model GroupMember {
  id        Int      @id @default(autoincrement())
  groupId   Int
  userId    Int
  createdAt DateTime @default(now())
  group     Group    @relation(fields: [groupId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([groupId, userId])
}

model GroupMessage {
  id        Int      @id @default(autoincrement())
  content   String
  createdAt DateTime @default(now())
  groupId   Int
  authorId  Int
  author    User     @relation(fields: [authorId], references: [id])
  group     Group    @relation(fields: [groupId], references: [id])
}

model Event {
  id          Int             @id @default(autoincrement())
  title       String
  description String?
  location    String
  date        DateTime
  category    String
  createdAt   DateTime        @default(now())
  authorId    Int
  capacity    Int?
  endTime     DateTime?
  groupId     Int?
  imageUrl    String?
  recurring   Boolean         @default(false)
  author      User            @relation(fields: [authorId], references: [id])
  attendees   EventAttendee[]
}

model EventAttendee {
  id        Int      @id @default(autoincrement())
  eventId   Int
  userId    Int
  checkedIn Boolean @default(false)
  createdAt DateTime @default(now())
  event     Event    @relation(fields: [eventId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([eventId, userId])
}

model Notification {
  id        Int      @id @default(autoincrement())
  type      String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
}

model Business {
  id          Int                @id @default(autoincrement())
  name        String
  description String?
  category    String
  location    String
  website     String?
  phone       String?
  email       String?
  createdAt   DateTime           @default(now())
  ownerId     Int
  owner       User               @relation(fields: [ownerId], references: [id])
  followers   BusinessFollower[]
}

model BusinessFollower {
  id         Int      @id @default(autoincrement())
  businessId Int
  userId     Int
  createdAt  DateTime @default(now())
  business   Business @relation(fields: [businessId], references: [id])
  user       User     @relation(fields: [userId], references: [id])

  @@unique([businessId, userId])
}

model Resource {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  type        String
  url         String
  thumbnail   String?
  createdAt   DateTime @default(now())
  authorId    Int
  author      User     @relation(fields: [authorId], references: [id])
}

model Asset {
  id              Int      @id @default(autoincrement())
  title           String   
  description     String?
  type            String   
  category        String   
  imageUrl        String?
  location        String?  
  createdAt       DateTime @default(now())
  availableFrom   DateTime?
  availableUntil  DateTime?
  daysAvailable   String?   
  isAvailable   Boolean   @default(true) 
  quantity        Int?      @default(1)
  amount          Float?    
  peopleCount     Int?     
  hourlyRate      Float?    
  capacity        Int?      
  dailyRate       Float?    
  authorId        Int
  author          User     @relation(fields: [authorId], references: [id])
}

model Connection {
  id         Int      @id @default(autoincrement())
  fromUserId Int
  toUserId   Int
  status     String   @default("pending")
  createdAt  DateTime @default(now())
  fromUser   User     @relation("ConnectionFrom", fields: [fromUserId], references: [id])
  toUser     User     @relation("ConnectionTo", fields: [toUserId], references: [id])

  @@unique([fromUserId, toUserId])
}

model GroupPost {
  id        Int       @id @default(autoincrement())
  content   String
  imageUrl  String?
  createdAt DateTime? @default(now()) @db.Timestamp(6)
  groupId   Int?
  authorId  Int?
  author    User?     @relation("GroupPostAuthor", fields: [authorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  group     Group?    @relation(fields: [groupId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model GroupReview {
  id        Int       @id @default(autoincrement())
  rating    Int
  comment   String?
  createdAt DateTime? @default(now()) @db.Timestamp(6)
  groupId   Int?
  authorId  Int?
  author    User?     @relation("GroupReviewAuthor", fields: [authorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  group     Group?    @relation(fields: [groupId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([groupId, authorId])
}

model SmartGoal {
  id           Int       @id @default(autoincrement())
  description  String
  checkIns     Int      @default(0)
  status       String   @default("active")
  measurable   Boolean?  @default(false)
  hub          String?
  startDate    String?
  duration     String?
  durationUnit String?
  groupId      Int?
  createdAt    DateTime? @default(now()) @db.Timestamp(6)
  userId       Int?
  user         User?     @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}
